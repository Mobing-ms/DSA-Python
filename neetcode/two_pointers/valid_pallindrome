class Solution:
    def isPalindrome(self, s: str) -> bool:
        new_s = ""
        for ch in s:
            if ch.isalnum():
                new_s += ch
            else:
                continue
        new_s = new_s.lower()

        if new_s[0:] == new_s[::-1]:
            return True
        else:
            return False